# n8n — LOCAL (development). Replace the n8n block + APP_URL in .env with this block, then: php artisan config:clear
# APP_URL: use when you only use the app at http://localhost:8000 (no ngrok).
APP_URL=http://localhost:8000
# Webhook URL used: http://localhost:5678/webhook/saas-events
N8N_WEBHOOK_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SEGMENT=webhook
N8N_USE_ROUTER=true
N8N_ROUTER_PATH=saas-events
# Token n8n must send in X-Automation-Token when calling POST /api/automation (use same value in n8n).
AUTOMATION_RUNNER_TOKEN=your-secret-token
