# n8n — CLOUD. Replace the n8n block + APP_URL in .env with this block, then: php artisan config:clear
# APP_URL: must be your public URL (e.g. ngrok) so n8n Cloud can call POST /api/automation. Replace with your actual ngrok URL.
APP_URL=https://your-ngrok-subdomain.ngrok-free.dev
# Webhook URL used: https://n8n.srv1243978.hstgr.cloud/webhook/saas-events (use webhook-test for test mode)
N8N_WEBHOOK_BASE_URL=https://n8n.srv1243978.hstgr.cloud
N8N_WEBHOOK_SEGMENT=webhook
N8N_USE_ROUTER=true
N8N_ROUTER_PATH=saas-events
# Token n8n must send in X-Automation-Token when calling POST /api/automation (use same value in n8n).
AUTOMATION_RUNNER_TOKEN=your-secret-token
